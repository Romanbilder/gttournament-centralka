{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Centrálka",
  "colors": {
    "primary": "#F7A400",
    "light": "#FBC900",
    "dark": "#1D252C"
  },
  "favicon": "/images/Datovýzdroj2PNG100.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": "/images/Profilovýobrázek800x800.png",
  "navbar": {
    "links": [
      {
        "label": "Web",
        "href": "https://gttournament.cz/"
      },
      {
        "label": "Google Drive",
        "href": "https://drive.google.com/drive/u/0/folders/0AG4YwrVfLOA_Uk9PVA"
      },
      {
        "label": "Twitch A",
        "href": "https://www.twitch.tv/gttournament_a"
      },
      {
        "label": "Twitch B",
        "href": "https://www.twitch.tv/gttournament_b"
      },
      {
        "label": "Twitch C",
        "href": "https://www.twitch.tv/gttournament_c"
      },
      {
        "label": "Twitch D",
        "href": "https://www.twitch.tv/gttournament_d"
      },
      {
        "label": "Admin",
        "href": "https://admin.gttournament.cz/"
      },
      {
        "label": "Registrace",
        "href": "https://login.gttournament.cz/"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "appearance": {
    "strict": false,
    "default": "system"
  },
  "fonts": {
    "heading": {
      "family": "Orbitron"
    },
    "body": {
      "family": "Montserrat"
    }
  },
  "description": "Pouze pro organizátory",
  "background": {
    "decoration": "windows"
  },
  "search": {
    "prompt": "Zeptej se Viotala šunčičko ;)"
  },
  "footer": {
    "socials": {
      "website": "https://gttournament.cz/",
      "instagram": "https://www.instagram.com/gttournament.official/",
      "youtube": "https://www.youtube.com/@gttournament",
      "discord": "https://discord.com/invite/WXtGFxrAdR",
      "x": "https://x.com/gttournament"
    }
  }
}
