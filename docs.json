{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Centrálka",
  "colors": {
    "primary": "#F7A400",
    "light": "#FBC900",
    "dark": "#1D252C"
  },
  "favicon": "/images/Datovýzdroj2PNG100.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": "/images/Profilovýobrázek800x800.png",
  "navbar": {
    "links": [
      {
        "label": "Web",
        "href": "https://gttournament.cz/"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "appearance": {
    "strict": true,
    "default": "dark"
  },
  "fonts": {
    "heading": {
      "family": "Orbitron"
    },
    "body": {
      "family": "Montserrat"
    }
  },
  "description": "Pouze pro organizátory",
  "background": {
    "decoration": "grid",
    "image": "/images/COVER.png"
  },
  "search": {
    "prompt": "Zeptej se Viotala šunčičko ;)"
  }
}
